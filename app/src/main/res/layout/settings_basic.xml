<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvSettingsTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:text="@string/settings_title"
            android:textAppearance="@style/TextAppearance.Material3.TitleLarge"
            android:textColor="@color/neon_blue" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/swTts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="@string/settings_tts_label"
            android:textColor="#FFFFFF" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/swVibrate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:checked="true"
            android:text="@string/settings_vibrate_label"
            android:textColor="#FFFFFF" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/swCopy"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:checked="true"
            android:text="@string/settings_copy_label"
            android:textColor="#FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="App Theme"
            android:textColor="@color/neon_blue"
            android:fontFamily="sans-serif-medium" />

        <RadioGroup
            android:id="@+id/rgTheme"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <RadioButton android:id="@+id/rbNeon" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Neon Cyan (Default)" android:textColor="#FFFFFF" />
            <RadioButton android:id="@+id/rbPurple" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Cyber Purple" android:textColor="#FFFFFF" />
            <RadioButton android:id="@+id/rbMatrix" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Matrix Green" android:textColor="#FFFFFF" />
            <RadioButton android:id="@+id/rbVaporwave" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Vaporwave (Gen Z)" android:textColor="#FFFFFF" />
            <RadioButton android:id="@+id/rbLuxury" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Premium Gold" android:textColor="#FFFFFF" />
            <RadioButton android:id="@+id/rbMidnight" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Midnight Ruby" android:textColor="#FFFFFF" />
            <RadioButton android:id="@+id/rbNordic" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Nordic Ice" android:textColor="#FFFFFF" />
            <RadioButton android:id="@+id/rbSynthwave" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Synthwave Orange" android:textColor="#FFFFFF" />
            <RadioButton android:id="@+id/rbGlitch" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Digital Glitch (Yellow)" android:textColor="#FFFFFF" />
            <RadioButton android:id="@+id/rbSakura" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Sakura Pink (Aesthetic)" android:textColor="#FFFFFF" />
        </RadioGroup>

    </LinearLayout>
</ScrollView>
